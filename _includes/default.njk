{% extends 'blades/html.njk' %}
{% set content_for_header %}
  <meta name="generator" content="{{ site.generator }}" />
  <style>
    body {
      padding-block: 3em;
      > footer {
        text-align: center;
        border: none;
      }
    }
  </style>
{% endset %}

{% block body %}
  <main class="container breakout-all prose lg:prose-xl xl:prose-2xl">{{ content | safe }}</main>
  <footer class="container prose">
    <hr />
    {{ site.footer | safe }} © {{ site.year }}
  </footer>
{% endblock %}
